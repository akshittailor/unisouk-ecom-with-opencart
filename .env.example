PORT=3000

# Redis
# In docker-compose: redis
# In local npm run start:dev: localhost
# Port 6379
REDIS_HOST=
REDIS_PORT=

# OpenCart Connectivity
# In docker-compose unified stack: http://opencart
# In local host mode: http://localhost:8080
OPENCART_BASE_URL=

# Auth mode:
# bridge = use custom adapter secret header (recommended for OpenCart 4.1.0.2). Keep this
# login  = legacy api/login token flow
OPENCART_AUTH_MODE=

# Legacy login settings (used only if OPENCART_AUTH_MODE=login)
OPENCART_API_USERNAME=Default
OPENCART_API_KEY=replace_with_opencart_api_key
OPENCART_AUTH_ROUTE=/index.php?route=api/login
OPENCART_INCLUDE_API_TOKEN_QUERY=false

# Bridge auth secret (recommended)
# Keep this "bridgeTempToken"
OPENCART_BRIDGE_SECRET=replace_with_shared_secret

# OpenCart Custom Adapter Routes
# Product Route = /index.php?route=custom/products
# Order Route = /index.php?route=custom/orders
# Inventory route = /index.php?route=custom/inventory
OPENCART_PRODUCTS_ROUTE=
OPENCART_ORDERS_ROUTE=
OPENCART_INVENTORY_ROUTE=

# Inventory Sync
LOW_STOCK_THRESHOLD=5
PROCESSING_STATUSES=processing,confirmed

# Negative stock policy:
# reject = fail sync when stock would go below 0
# clamp  = set stock to 0
NEGATIVE_STOCK_POLICY=reject
