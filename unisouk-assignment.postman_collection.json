			"item": [
				{
					"name": "OpenCart Login (Optional Token Store)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"let json = {};",
									"try {",
									"  json = pm.response.json();",
									"} catch (e) {}",
									"const token = json.api_token || json.token || (json.data && (json.data.api_token || json.data.token));",
									"if (token) {",
									"  pm.environment.set('opencart_api_token', token);",
									"  pm.environment.set('Authorization', `Bearer ${token}`);",
									"}",
									"pm.test('Login succeeded or returned a token', function () {",
									"  pm.expect(pm.response.code).to.be.oneOf([200, 204, 400, 401, 403]);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "username",
									"value": "{{opencart_api_username}}",
									"type": "text"
								},
								{
									"key": "key",
									"value": "{{opencart_api_key}}",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{opencart_base_url}}/index.php?route=api/login",
							"host": [
								"{{opencart_base_url}}"
							],
							"path": [
								"index.php"
							],
							"query": [
								{
									"key": "route",
									"value": "api/login"
								}
							]
						},
						"description": "Legacy OpenCart API login. If your installation returns an api_token/token, this request stores it automatically in the active Postman environment."
					},
					"response": []
				}
			]
