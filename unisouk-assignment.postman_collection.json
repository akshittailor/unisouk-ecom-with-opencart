							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"const res = pm.response.json();",
											"// Resilient parsing: Check if it's an array, a data wrapper, or a direct object",
											"let stock = 0;",
											"if (Array.isArray(res)) stock = res[0].quantity;",
											"else if (res.data && res.data.quantity !== undefined) stock = res.data.quantity;",
											"else stock = res.quantity;",
											"",
											"pm.collectionVariables.set('pre_sync_stock', String(stock));",
											"console.log('Initial Stock Recorded:', stock);",
											"pm.test('Initial stock is a number', () => pm.expect(Number(stock)).to.be.a('number'));"
										],
										"type": "text/javascript"
									}
								}
