											"key": "productId",
											"value": "{{product_id}}"
										}
									]
								}
							},
							"response": []
						},
						{
							"name": "4. Create Order for this Product",
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"const res = pm.response.json();",
											"const oid = res.orderId || (res.data ? res.data.orderId : null);",
											"pm.collectionVariables.set('order_id', String(oid));",
											"pm.test('Order created', () => pm.expect(oid).to.not.be.null);"
										],
										"type": "text/javascript"
									}
								}
							],
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									},
									{
										"key": "Cookie",
										"value": "OCSESSID=50ca551e80507d3299d3faecda"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"customer\": {\n    \"firstname\": \"Reviewer\",\n    \"lastname\": \"Tester\",\n    \"email\": \"test@example.com\",\n    \"telephone\": \"123456\"\n  },\n  \"products\": [\n    {\n      \"productId\": {{product_id}},\n      \"quantity\": 5\n    }\n  ],\n  \"shippingMethod\": \"Flat Rate\",\n  \"paymentMethod\": \"COD\"\n}"
								},
								"url": {
									"raw": "{{base_url}}/orders/create",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"orders",
										"create"
									]
								}
							},
							"response": []
						},
						{
							"name": "5. Update Status (Trigger Sync)",
							"request": {
								"method": "PATCH",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"status\": \"processing\",\n  \"triggerInventorySync\": true\n}"
								},
								"url": {
									"raw": "{{base_url}}/orders/{{order_id}}/status",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"orders",
										"{{order_id}}",
										"status"
									]
								}
							},
							"response": []
						},
						{
							"name": "6. FINAL VERIFICATION: Check Inventory Decrement",
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"const res = pm.response.json();",
											"// Resilient parsing: Handle Array or Object",
											"let finalStock = 0;",
											"if (Array.isArray(res)) finalStock = res[0].quantity;",
											"else if (res.data && res.data.quantity !== undefined) finalStock = res.data.quantity;",
											"else finalStock = res.quantity;",
											"",
											"const initialStock = Number(pm.collectionVariables.get('pre_sync_stock'));",
											"const currentStock = Number(finalStock);",
											"",
											"console.log('Comparison -> Initial:', initialStock, 'Final:', currentStock);",
											"",
											"pm.test('PASSED: Stock reduced from ' + initialStock + ' to ' + currentStock, function () {",
											"    // Use to.be.below for strict comparison",
											"    pm.expect(currentStock).to.be.below(initialStock);",
											"});"
										],
										"type": "text/javascript"
									}
								}
							],
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/inventory?productId={{product_id}}",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"inventory"
									],
									"query": [
										{
											"key": "productId",
											"value": "{{product_id}}"
										}
									]
								}
							},
							"response": []
						}
					]
				}
			],
